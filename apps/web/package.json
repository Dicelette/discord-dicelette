		"react-router-dom": "^6.30.0"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.5",
		"@types/express-session": "^1.18.1",
		"@types/node": "^22.0.0",
		"@types/react": "^18.3.23",
