{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"baseUrl": ".",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"noEmit": true,
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"paths": {
			"@shared/*": ["./src/shared/src/*"],
			"@shared": ["./src/shared/index.js"],
			"@dicelette/parse_result": ["../../packages/parse_result/index.ts"],
			"@dicelette/utils": ["./src/shims/dicelette-utils-browser.ts"],
			"@dicelette/utils/*": ["../../packages/utils/src/*"],
			"@dicelette/types": ["../../packages/types/index.ts"],
			"@dicelette/localization": ["../../packages/localization/index.ts"]
		}
	},
	"include": ["src", "vite.config.ts", "tests/**/*", "../../dashboard/api/**/*"]
}
