{
	"name": "dicelette",
	"version": "2.37.7",
	"private": true,
	"type": "module",
	"author": "Mara-Li",
	"license": "GNU GPLv3",
	"keywords": [],
	"engines": {
		"node": ">=24"
	},
	"engineStrict": true,
	"scripts": {
		"build": "tsc --build && tsc-alias",
		"dev": "tsx watch --clear-screen=false packages/bot/index.ts",
		"dev:prod": "cross-env PROD=true tsx watch --clear-screen=false packages/bot/index.ts",
		"lint": "biome check --write ./packages/ --unsafe",
		"pm2:delete": "pm2 delete dicelette",
		"pm2:restart": "npm run build && pm2 restart dicelette",
		"pm2:start": "npm run build && pm2 start dist/packages/bot/index.js --name dicelette --log-date-format=\"YYYY-MM-DD HH:mm Z\"",
		"pm2:stop": "pm2 stop dicelette",
		"predev": "tsx packages/localization/docs/build-help.ts",
		"prepare": "husky",
		"prerelease": "tsc --skipLibCheck --noEmit",
		"release": "commit-and-tag-version",
		"postrelease": "git push --follow-tags origin main",
		"test": "vitest run"
	},
	"dependencies": {
		"@dicelette/core": "^1.26.0",
		"@discordjs/rest": "^2.4.2",
		"@sentry/node": "^10.42.0",
		"@sentry/profiling-node": "^10.42.0",
		"canvas": "^3.0.1",
		"chart.js": "4.4.8",
		"chartjs-node-canvas": "^5.0.0",
		"dedent": "^1.7.2",
		"discord-api-types": "^0.37.115",
		"discord.js": "14.25.0",
		"dotenv": "^17.3.1",
		"enmap": "npm:@dicelette/enmap",
		"express": "^5.1.0",
		"fast-deep-equal": "^3.1.3",
		"i18next": "^25.8.13",
		"klona": "^2.0.6",
		"mathjs": "^14.0.1",
		"parse-color": "^1.0.0",
		"random-js": "^2.1.0",
		"tslog": "^4.10.2",
		"tsx": "^4.21.0",
		"uniformize": "^2.5.0",
		"zod": "latest"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@types/express": "^5.0.5",
		"@types/node": "^22.19.13",
		"@types/papaparse": "^5.3.15",
		"@types/parse-color": "^1.0.3",
		"@types/semver": "^7.7.0",
		"commit-and-tag-version": "^12.6.1",
		"cross-env": "^10.1.0",
		"glob": "^13.0.6",
		"husky": "^9.1.7",
		"moment": "^2.30.1",
		"nodemon": "^3.1.14",
		"papaparse": "^5.4.1",
		"rimraf": "^6.1.3",
		"semver": "^7.7.2",
		"strip-ansi": "^7.2.0",
		"ts-deepmerge": "^7.0.3",
		"ts-loader": "^9.5.4",
		"tsc-alias": "^1.8.16",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.0.16"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"@sentry-internal/node-cpu-profiler",
			"better-sqlite3",
			"canvas",
			"esbuild"
		]
	},
	"commit-and-tag-version": {
		"bumpFiles": [
			{
				"filename": "package.json",
				"type": "json"
			}
		],
		"t": ""
	}
}
