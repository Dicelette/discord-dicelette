{
	"name": "dicelette",
	"version": "3.14.0",
	"private": true,
	"type": "module",
	"author": "Mara-Li",
	"license": "GNU GPLv3",
	"keywords": [],
	"engines": {
		"node": "24.14.0"
	},
	"engineStrict": true,
	"scripts": {
		"build": "tsc --build && tsc-alias",
		"localization:build": "tsx packages/localization/docs/build-help.ts --build",
		"postbuild": "pnpm localization:build && pnpm dashboard:build",
		"dev": "tsx watch --clear-screen=false apps/bot/index.ts",
		"bot:watch": "tsx watch --clear-screen=false apps/bot/index.ts",
		"dashboard:release": "pnpm --filter @dicelette/web release",
		"postdashboard:release": "pnpm postrelease",
		"dashboard:build": "pnpm --filter @dicelette/web build",
		"dev:prod": "cross-env PROD=true tsx watch --clear-screen=false apps/bot/index.ts",
		"lint": "biome check --write ./apps/ ./packages/ ./dashboard --unsafe",
		"pm2:delete": "pm2 delete dicelette",
		"pm2:restart": "pnpm run build && pm2 restart dicelette",
		"pm2:start": "pnpm run build && pm2 start dist/apps/bot/index.js --name dicelette --log-date-format=\"YYYY-MM-DD HH:mm Z\"",
		"pm2:stop": "pm2 stop dicelette",
		"predev": "tsx packages/localization/docs/build-help.ts",
		"prepare": "husky",
		"prerelease": "tsc --skipLibCheck --noEmit",
		"release": "commit-and-tag-version",
		"postrelease": "git push --follow-tags origin main",
		"test": "vitest run",
		"test:e2e": "pnpm --filter @dicelette/web test:e2e"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"dependencies": {
		"@dicelette/core": "^1.28.1",
		"@discordjs/rest": "^2.6.1",
		"@sentry/node": "^10.48.0",
		"@sentry/profiling-node": "^10.48.0",
		"canvas": "^3.2.3",
		"chart.js": "4.5.1",
		"chartjs-node-canvas": "^5.0.0",
		"cors": "^2.8.5",
		"dedent": "^1.7.2",
		"discord-api-types": "^0.38.46",
		"discord.js": "14.26.3",
		"dotenv": "^17.4.2",
		"enmap": "npm:@dicelette/enmap",
		"express": "^5.1.0",
		"express-session": "^1.18.1",
		"fast-deep-equal": "^3.1.3",
		"i18next": "^26.0.5",
		"klona": "^2.0.6",
		"mathjs": "^15.2.0",
		"memorystore": "^1.6.7",
		"parse-color": "^1.0.0",
		"random-js": "^2.1.0",
		"tslog": "^4.10.2",
		"tsx": "^4.21.0",
		"uniformize": "^2.5.0",
		"zod": "latest"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@go-task/cli": "^3.50.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.5",
		"@types/express-session": "^1.18.1",
		"@types/node": "^25.6.0",
		"@types/papaparse": "^5.3.15",
		"@types/parse-color": "^1.0.3",
		"@types/semver": "^7.7.0",
		"commit-and-tag-version": "^12.7.1",
		"concurrently": "^9.1.2",
		"cross-env": "^10.1.0",
		"glob": "^13.0.6",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"moment": "^2.30.1",
		"nodemon": "^3.1.14",
		"papaparse": "^5.4.1",
		"rimraf": "^6.1.3",
		"semver": "^7.7.2",
		"strip-ansi": "^7.2.0",
		"ts-deepmerge": "^7.0.3",
		"ts-loader": "^9.5.4",
		"tsc-alias": "^1.8.16",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"@go-task/cli",
			"@sentry-internal/node-cpu-profiler",
			"better-sqlite3",
			"canvas",
			"esbuild"
		]
	},
	"commit-and-tag-version": {
		"bumpFiles": [
			{
				"filename": "package.json",
				"type": "json"
			}
		],
		"t": ""
	}
}
