{
	"name": "dicelette",
	"version": "4.0.1",
	"private": true,
	"type": "module",
	"author": "Mara-Li",
	"license": "GNU GPLv3",
	"keywords": [],
	"engines": {
		"node": "24.14.0"
	},
	"engineStrict": true,
	"scripts": {
		"build": "tsc --build && tsc-alias",
		"localization:build": "tsx packages/localization/docs/build-help.ts --build",
		"postbuild": "pnpm localization:build && pnpm dashboard:build",
		"dev": "tsx watch --clear-screen=false apps/bot/index.ts",
		"bot:watch": "tsx watch --clear-screen=false apps/bot/index.ts",
		"dashboard:release": "pnpm --filter @dicelette/web release",
		"postdashboard:release": "pnpm postrelease",
		"dashboard:build": "pnpm --filter @dicelette/web build",
		"dev:prod": "cross-env PROD=true tsx watch --clear-screen=false apps/bot/index.ts",
		"lint": "biome check --write ./apps/ ./packages/ ./dashboard --unsafe",
		"pm2:delete": "pm2 delete dicelette",
		"pm2:restart": "pnpm run build && pm2 restart dicelette",
		"pm2:start": "pnpm run build && pm2 start dist/apps/bot/index.js --name dicelette --log-date-format=\"YYYY-MM-DD HH:mm Z\"",
		"pm2:stop": "pm2 stop dicelette",
		"predev": "tsx packages/localization/docs/build-help.ts",
		"prepare": "husky",
		"prerelease": "tsc --skipLibCheck --noEmit",
		"release": "commit-and-tag-version",
		"postrelease": "git push --follow-tags origin main",
		"test": "vitest run",
		"test:e2e": "pnpm --filter @dicelette/web test:e2e"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"dependencies": {
		"@dicelette/core": "^1.28.3",
		"@discordjs/rest": "^2.6.1",
		"@sentry/node": "^10.55.0",
		"@sentry/profiling-node": "^10.55.0",
		"canvas": "^3.2.3",
		"chart.js": "4.5.1",
		"chartjs-node-canvas": "^5.0.0",
		"cors": "^2.8.6",
		"dedent": "^1.7.2",
		"discord-api-types": "^0.38.48",
		"discord.js": "14.26.4",
		"dotenv": "^17.4.2",
		"enmap": "npm:@dicelette/enmap@^6.1.6",
		"express": "^5.2.1",
		"express-session": "^1.19.0",
		"fast-deep-equal": "^3.1.3",
		"i18next": "^26.3.0",
		"klona": "^2.0.6",
		"mathjs": "^15.2.0",
		"memorystore": "^1.6.8",
		"parse-color": "^1.0.0",
		"random-js": "^2.1.0",
		"tslog": "^4.10.2",
		"tsx": "^4.22.0",
		"uniformize": "^2.6.1",
		"zod": "latest"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@go-task/cli": "^3.50.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/express-session": "^1.19.0",
		"@types/node": "^25.8.0",
		"@types/papaparse": "^5.5.2",
		"@types/parse-color": "^1.0.3",
		"@types/semver": "^7.7.1",
		"commit-and-tag-version": "^12.7.3",
		"concurrently": "^10.0.0",
		"cross-env": "^10.1.0",
		"glob": "^13.0.6",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.6",
		"moment": "^2.30.1",
		"nodemon": "^3.1.14",
		"papaparse": "^5.5.3",
		"rimraf": "^6.1.3",
		"semver": "^7.8.0",
		"strip-ansi": "^7.2.0",
		"ts-deepmerge": "^8.0.0",
		"ts-loader": "^9.6.0",
		"tsc-alias": "^1.8.17",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"@go-task/cli",
			"@sentry-internal/node-cpu-profiler",
			"better-sqlite3",
			"canvas",
			"esbuild"
		],
		"commit-and-tag-version": {
			"bumpFiles": [
				{
					"filename": "package.json",
					"type": "json"
				}
			],
			"t": ""
		},
		"packageManager": "pnpm@11.1.2",
		"overrides": {
			"mathjs@>=13.1.1 <15.2.0": ">=15.2.0",
			"mathjs@>=13.1.0 <15.2.0": ">=15.2.0",
			"qs@>=6.11.1 <=6.15.1": ">=6.15.2",
			"@dicelette/core": "link:../core"
		}
	}
}
