{
	"compilerOptions": {
		"allowJs": true,
		"allowSyntheticDefaultImports": true,
		"baseUrl": ".",
		"checkJs": false,
		"composite": false,
		"declaration": false,
		"declarationMap": false,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"forceConsistentCasingInFileNames": true,
		"importHelpers": true,
		"inlineSourceMap": true,
		"lib": ["ESNext", "DOM"],
		"module": "esnext",
		"moduleResolution": "node",
		"outDir": "./dist/",
		"incremental": true,
		"tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo",
		"paths": {
			"@dicelette/bot": ["packages/bot/index.js"],
			"@dicelette/bot-helpers": ["packages/bot-helpers/index.js"],
			"@dicelette/client": ["packages/client/index.js"],
			"@dicelette/localization": ["packages/localization/index.js"],
			"@dicelette/parse_result": ["packages/parse_result/index.js"],
			"@dicelette/types": ["packages/types/index.js"],
			"@dicelette/utils": ["packages/utils/index.js"],
			"@dicelette/discord_ext": ["packages/localization/src/discord_ext.js"],
			"client": ["packages/bot/src/client.js"],
			"commands": ["packages/bot/src/commands/index.js"],
			"database": ["packages/bot/src/database/index.js"],
			"discord_ext": ["packages/bot/src/discord_ext.js"],
			"event": ["packages/bot/src/events/index.js"],
			"event/*": ["packages/bot/src/events/*"],
			"features": ["packages/bot/src/features/index.js"],
			"locales": ["packages/bot/src/locales.js"],
			"messages": ["packages/bot/src/messages/index.js"],
			"utils": ["packages/bot/src/utils/index.js"]
		},
		"removeComments": true,
		"resolveJsonModule": true,
		"rootDir": "./",
		"skipLibCheck": true,
		"sourceMap": false,
		"strict": true,
		"target": "ESNext",
		"typeRoots": ["packages/@types", "node_modules/@types"],
		"jsx": "react-jsx"
	},
	"exclude": [
		"node_modules",
		"dist",
		"**/*.test.ts",
		"packages/**/tests/**",
		"packages/**/vitest.config.ts",
		"@testing/**",
		"packages/localization/docs/**"
	],
	"include": [
		"packages/**/*.ts",
		"packages/**/*.tsx",
		"packages/**/*.d.ts",
		"package.json"
	],
	"ts-node": {
		"esm": true,
		"experimentalSpecifierResolution": "node",
		"require": ["tsconfig-paths/register"],
		"transpileOnly": true
	},
	"tsc-alias": {
		"resolveFullPaths": true
	}
}
